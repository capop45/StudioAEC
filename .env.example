# Estúdio AEC — variáveis do app Next.js (web/)
# Deploy local: scripts/deploy-local.ps1 (usa scripts/deploy/secrets.local.env)
# Deploy produção: scripts/deploy-production.ps1 (usa secrets.production.env)

# PostgreSQL + pgvector
DATABASE_URL=postgresql://studioaec:studioaec@localhost:5432/studioaec?schema=public

# Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Checkout + webhook /api/webhooks/stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_RESTRICTED_KEY=rk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (tutor RAG)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# AWS S3 (biblioteca)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
S3_BUCKET=studio-aec-bucket
S3_LIBRARY_PREFIX=library
S3_PRESIGN_EXPIRES_SECONDS=300

# Opcional
AI_GATEWAY_API_KEY=
PRISMA_SERVICE_TOKEN=
CLERK_ADMIN_USER_IDS=
CLERK_ADMIN_USERNAMES=
