# Estúdio AEC — variáveis do app Next.js (web/)
# Copie para web/.env.local para desenvolvimento

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# PostgreSQL + pgvector (Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/studioaec?schema=public

# Stripe (Checkout + webhook /api/webhooks/stripe)
STRIPE_RESTRICTED_KEY=rk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (tutor RAG — opcional)
OPENAI_API_KEY=

# AWS S3 (biblioteca)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
S3_BUCKET=studio-aec-bucket
AI_GATEWAY_API_KEY=

# Legado Docker (frontend Vite + API .NET) — deprecado
JWT_KEY=mude-esta-chave-em-producao-minimo-32-caracteres-aqui!!
JWT_ISSUER=StudioAEC
JWT_AUDIENCE=StudioAEC
WEB_PORT=80
